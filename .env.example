# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# All default to claude-opus-4-8 for best clue quality, editing, repair, and explain.
# Override individually to reduce cost (e.g. ANTHROPIC_EXPLAIN_MODEL=claude-sonnet-4-6)
# ANTHROPIC_SETTER_MODEL=claude-opus-4-8
# ANTHROPIC_CRITIC_MODEL=claude-opus-4-8
# ANTHROPIC_REPAIR_MODEL=claude-opus-4-8
# ANTHROPIC_EXPLAIN_MODEL=claude-opus-4-8

# SQLite — users, credits, and clue archive (defaults to ./data/clues.db)
# Local: ./data/clues.db
# Railway: mount a volume at /data and set DATABASE_PATH=/data/clues.db
# DATABASE_PATH=./data/clues.db

# Session signing secret — required in production
# SESSION_SECRET=generate-a-long-random-string

# Public site URL (used in verification emails and share links)
# APP_URL=https://www.crypticai.uk
# NEXT_PUBLIC_SITE_URL=https://www.crypticai.uk

# Email verification — https://resend.com/
# RESEND_API_KEY=re_your-key-here
# EMAIL_FROM=CrypticAI <onboarding@crypticai.uk>

# Stripe credit purchases — https://dashboard.stripe.com/test/apikeys
# Minimum: STRIPE_SECRET_KEY (checkout works with inline pricing)
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
# Optional — run `npm run setup:stripe` to create reusable prices:
# STRIPE_PRICE_ID_6=price_...   ($3 for 6 credits)
# STRIPE_PRICE_ID_12=price_...  ($5 for 12 credits)
# Legacy alias for the 12-credit pack:
# STRIPE_PRICE_ID=price_...
# STRIPE_CURRENCY=usd
# Webhook for production (local dev can rely on checkout success confirm instead):
# STRIPE_WEBHOOK_SECRET=whsec_...
